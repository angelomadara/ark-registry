{
  "name": "the-ark-registry",
  "version": "1.1.1",
  "description": "Backend for The Ark Registry",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/src/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "migrate": "docker exec ark-backend npx tsx src/scripts/migrate.ts up",
    "migrate:rollback": "docker exec ark-backend npx tsx src/scripts/migrate.ts down",
    "migrate:status": "docker exec ark-backend npx tsx src/scripts/migrate.ts status"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exifr": "^7.1.3",
    "express": "^4.18.2",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.11.3",
    "sharp": "^0.35.3",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.43",
    "@types/pg": "^8.20.0",
    "@types/sharp": "^0.31.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
